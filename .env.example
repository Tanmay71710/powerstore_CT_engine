# Environment Configuration Example
# Copy this file to .env and .env.{environment} for your local setup
# These values override the Python configuration files

# Environment Detection
ENVIRONMENT=development

# Database Configuration (matches shared/config/base.py)
ENV_DATABASE_HOST=10.55.236.78
ENV_DATABASE_PORT=5432
ENV_DATABASE_NAME=qTest
ENV_DATABASE_USER=postgres
ENV_DATABASE_PASSWORD=postgres
ENV_DATABASE_SSL_MODE=prefer
ENV_DATABASE_POOL_SIZE=5
ENV_DATABASE_MAX_OVERFLOW=10

# Performance Database Configuration
ENV_PERF_DATABASE_NAME=performance

# Jenkins Configuration (consistent across all environments)
ENV_JENKINS_URL=https://osj-ngm-03-prd.cec.delllabs.net
ENV_JENKINS_USERNAME=svc_prdsysqafw
ENV_JENKINS_PASSWORD=jenkins-password-from-vault
ENV_JENKINS_JOB_NAME=Trident/test_executer
ENV_JENKINS_DEV_JOB_NAME=Trident/dev_test_executer
ENV_JENKINS_TIMEOUT=300
ENV_JENKINS_RETRY_ATTEMPTS=3
ENV_JENKINS_RETRY_DELAY=5

# XPOOL Configuration
ENV_XPOOL_ENABLED=true
ENV_XPOOL_BINARY_PATH=/home/public/scripts/xpool_trident/prd/xpool
ENV_XPOOL_GROUPS=QA-TestRunner,FRAMEWORK
ENV_XPOOL_DEFAULT_USER=svc_prdsysqafw
ENV_XPOOL_TIMEOUT=300
ENV_XPOOL_RETRY_ATTEMPTS=3

# Application Configuration
ENV_APP_NAME=powerstore-ct-engine
ENV_APP_VERSION=4.0.0
ENV_DEBUG=false
ENV_SECRET_KEY=change-this-secret-key-in-production

# Server Configuration
ENV_HOST=0.0.0.0
ENV_PORT=5000

# Kubernetes Configuration
ENV_KUBERNETES_ENABLED=false
ENV_KUBERNETES_NAMESPACE=default
ENV_KUBERNETES_CONFIG_PATH=/usr/src/app/ns5
ENV_KUBERNETES_CONTEXT=

# LDAP Configuration
ENV_LDAP_URL=ldaps://amer.dell.com:3269
ENV_LDAP_BASE_DN=DC=dell,DC=com
ENV_LDAP_BIND_DN=CN=svc_prdsysqafw,OU=Service Accounts,DC=amer,DC=dell,DC=com
ENV_LDAP_USE_SSL=true
ENV_LDAP_TLS_VERSION=PROTOCOL_SSLv23
ENV_LDAP_CONNECT_TIMEOUT=10
ENV_LDAP_SEARCH_TIMEOUT=5

# Monitoring Configuration
ENV_MONITORING_ENABLED=true
ENV_MONITORING_INTERVAL=300
ENV_MONITORING_TIMEOUT=60

# Logging Configuration
ENV_LOG_LEVEL=INFO
ENV_LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
ENV_LOG_FILE=app.log

# Vault Configuration
ENV_VAULT_ENABLED=false
ENV_VAULT_URL=http://localhost:8200
ENV_VAULT_ROLE=powerstore-ct-engine
ENV_VAULT_SECRET_PATH=secret/powerstore-ct-engine
ENV_VAULT_AUTH_METHOD=kubernetes

# Feature Flags Configuration
ENV_FEATURE_FLAGS_ENABLED=true
ENV_FEATURE_FLAGS_CONFIG_PATH=feature_flags.json

# CORS Configuration
ENV_CORS_ENABLED=true
ENV_CORS_ORIGINS=*

# Security Configuration
ENV_SESSION_COOKIE_SECURE=false
ENV_SESSION_COOKIE_HTTPONLY=true
ENV_SESSION_COOKIE_SAMESITE=Lax

# API Configuration
ENV_API_PREFIX=/api/v1
ENV_API_TITLE=PowerStore CT Engine API
ENV_API_VERSION=1.0
ENV_API_DOC_ENABLED=true

# Test Execution Configuration
ENV_TEST_EXECUTION_TIMEOUT=7200
ENV_TEST_EXECUTION_RETRY_ATTEMPTS=2
ENV_TEST_EXECUTION_RETRY_DELAY=60
ENV_TEST_EXECUTION_MAX_CONCURRENT=10

# Cluster Management Configuration
ENV_CLUSTER_LEASE_TIMEOUT=7200
ENV_CLUSTER_RELEASE_DELAY=300
ENV_CLUSTER_HEALTH_CHECK_INTERVAL=60

# Email Configuration
ENV_EMAIL_ENABLED=false
ENV_EMAIL_SMTP_HOST=smtp.dell.com
ENV_EMAIL_SMTP_PORT=587
ENV_EMAIL_SMTP_USE_TLS=true
ENV_EMAIL_FROM_ADDRESS=powerstore-ct-engine@dell.com

# Slack Configuration
ENV_SLACK_ENABLED=false
ENV_SLACK_WEBHOOK_URL=
ENV_SLACK_DEFAULT_CHANNEL=#test-notifications

# Working Hours Configuration
ENV_WORKING_HOURS_ENABLED=false
ENV_WORKING_HOURS_START=09:00
ENV_WORKING_HOURS_END=18:00
ENV_WORKING_HOURS_TIMEZONE=America/New_York

# Cache Configuration
ENV_CACHE_ENABLED=true
ENV_CACHE_TYPE=simple
ENV_CACHE_REDIS_URL=redis://localhost:6379/0
ENV_CACHE_DEFAULT_TIMEOUT=300

# Rate Limiting Configuration
ENV_RATE_LIMITING_ENABLED=true
ENV_RATE_LIMIT_PER_MINUTE=60
ENV_RATE_LIMIT_PER_HOUR=1000

# File Upload Configuration
ENV_UPLOAD_ENABLED=true
ENV_UPLOAD_MAX_SIZE=10485760
ENV_UPLOAD_FOLDER=/tmp/uploads

# Backup Configuration
ENV_BACKUP_ENABLED=false
ENV_BACKUP_INTERVAL=86400
ENV_BACKUP_RETENTION_DAYS=30
ENV_BACKUP_FOLDER=/tmp/backups

# Health Check Configuration
ENV_HEALTH_CHECK_ENABLED=true
ENV_HEALTH_CHECK_INTERVAL=60
ENV_HEALTH_CHECK_TIMEOUT=10

# Metrics Configuration
ENV_METRICS_ENABLED=true
ENV_METRICS_PORT=9090
ENV_METRICS_PATH=/metrics
